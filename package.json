  },
  "homepage": "https://github.com/tejnathoo/vsw-future-planning#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@google/genai": "^2.10.0",
    "@slack/bolt": "^4.7.3",
    "@types/node": "^26.1.0",
    "csv-parse": "^7.0.1",
    "dotenv": "^17.4.2",
    "googleapis": "^173.0.0",
    "node-cron": "^3.0.3",
    "typescript": "^6.0.3"
  },
